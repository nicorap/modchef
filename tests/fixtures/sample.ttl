# A 2-deep runtime-dependency chain: ToolA -> ToolB -> ToolC.
<https://modchef.dev/r/m-toola-1-0-gcc-12-3-0> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gcc-12-3-0> ;
    mc:dependsOn <https://modchef.dev/r/m-toolb-1-0-gcc-12-3-0> ;
    mc:fullName "ToolA/1.0-GCC-12.3.0" ;
    mc:name "ToolA" ;
    mc:providesSoftware <https://modchef.dev/r/sw-toola> ;
    mc:version "1.0" .

<https://modchef.dev/r/m-toolb-1-0-gcc-12-3-0> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gcc-12-3-0> ;
    mc:dependsOn <https://modchef.dev/r/m-toolc-1-0-gcc-12-3-0> ;
    mc:fullName "ToolB/1.0-GCC-12.3.0" ;
    mc:name "ToolB" ;
    mc:providesSoftware <https://modchef.dev/r/sw-toolb> ;
    mc:version "1.0" .

<https://modchef.dev/r/m-toolc-1-0-gcc-12-3-0> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gcc-12-3-0> ;
    mc:fullName "ToolC/1.0-GCC-12.3.0" ;
    mc:name "ToolC" ;
    mc:providesSoftware <https://modchef.dev/r/sw-toolc> ;
    mc:version "1.0" .

<https://modchef.dev/r/sw-toola> a mc:Software ;
    mc:name "toola" .

<https://modchef.dev/r/sw-toolb> a mc:Software ;
    mc:name "toolb" .

<https://modchef.dev/r/sw-toolc> a mc:Software ;
    mc:name "toolc" .

# --- installed/available tiers (installed-vs-available feature) ---

# STAR: available in EasyBuild but NOT installed on this HPC
<https://modchef.dev/r/m-star-2-7-11a-gcc-12-3-0> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gcc-12-3-0> ;
    mc:fullName "STAR/2.7.11a-GCC-12.3.0" ;
    mc:installed false ;
    mc:name "STAR" ;
    mc:providesSoftware <https://modchef.dev/r/sw-star> ;
    mc:version "2.7.11a" .

<https://modchef.dev/r/sw-star> a mc:Software ;
    mc:name "star" .

# GATK present in both tiers: installed 4.5.0.0 shadows available 4.6.0.0
<https://modchef.dev/r/m-gatk-4-5-0-0-gcc-12-3-0> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gcc-12-3-0> ;
    mc:fullName "GATK/4.5.0.0-GCC-12.3.0" ;
    mc:installed true ;
    mc:name "GATK" ;
    mc:providesSoftware <https://modchef.dev/r/sw-gatk> ;
    mc:version "4.5.0.0" .

<https://modchef.dev/r/m-gatk-4-6-0-0-gcc-12-3-0> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gcc-12-3-0> ;
    mc:fullName "GATK/4.6.0.0-GCC-12.3.0" ;
    mc:installed false ;
    mc:name "GATK" ;
    mc:providesSoftware <https://modchef.dev/r/sw-gatk> ;
    mc:version "4.6.0.0" .

<https://modchef.dev/r/sw-gatk> a mc:Software ;
    mc:name "gatk" .

# A not-installed bundle whose exts_list happens to ship 'biopython' (like
# OpenFold). It also ships 'labpipe', which is provided by nothing else.
<https://modchef.dev/r/m-biotools-1-0-gfbf-2023a> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gfbf-2023a> ;
    mc:fullName "Biotools/1.0-gfbf-2023a" ;
    mc:installed false ;
    mc:name "Biotools" ;
    mc:providesPackage <https://modchef.dev/r/pkg-python-biopython>,
        <https://modchef.dev/r/pkg-python-labpipe> ;
    mc:providesSoftware <https://modchef.dev/r/sw-biotools> ;
    mc:version "1.0" .

<https://modchef.dev/r/pkg-python-biopython> a mc:Package ;
    mc:ecosystem "python" ;
    mc:name "biopython" .

<https://modchef.dev/r/pkg-python-labpipe> a mc:Package ;
    mc:ecosystem "python" ;
    mc:name "labpipe" .

<https://modchef.dev/r/sw-biotools> a mc:Software ;
    mc:name "biotools" .

# biopython installed as its OWN module (provides software 'biopython'), like
# the real Biopython/*. A --python biopython request must resolve to this, not
# to the Biotools bundle that merely lists biopython in its exts_list.
<https://modchef.dev/r/m-biopython-1-85-gfbf-2023a> a mc:Module ;
    mc:builtWith <https://modchef.dev/r/tc-gfbf-2023a> ;
    mc:fullName "Biopython/1.85-gfbf-2023a" ;
    mc:installed true ;
    mc:name "Biopython" ;
    mc:providesSoftware <https://modchef.dev/r/sw-biopython> ;
    mc:version "1.85" .

<https://modchef.dev/r/sw-biopython> a mc:Software ;
    mc:name "biopython" .

